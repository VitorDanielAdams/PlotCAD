# PlotCAD — Environment Variables (Production Template)
#
# Copy to .env.prod on the VPS and fill in real values:
#   cp .env.example /opt/plotcad/.env.prod
#
# NEVER commit the real .env.prod file to Git.

# ── Container Registry ───────────────────────────────────────────────────────
GHCR_OWNER=your-github-username
IMAGE_TAG=latest

# ── Database ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_TO_STRONG_PASSWORD

# ── JWT (Main App) ───────────────────────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=CHANGE_TO_JWT_SECRET
JWT_ISSUER=https://api.yourdomain.com.br
JWT_AUDIENCE=https://app.yourdomain.com.br

# ── JWT (Backoffice) — MUST be different from main JWT ───────────────────────
# Generate: openssl rand -base64 64
BACKOFFICE_JWT_SECRET=CHANGE_TO_DIFFERENT_SECRET

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_APP_ORIGIN=https://app.yourdomain.com.br
CORS_ADMIN_ORIGIN=https://admin.yourdomain.com.br
