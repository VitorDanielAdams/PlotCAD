{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/application-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}",
          "fileSizeLimitBytes": 10485760,
          "rollOnFileSizeLimit": true
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId",
      "WithEnvironmentUserName"
    ],
    "Properties": {
      "Application": "PlotCAD.WebApi"
    }
  },
  "Database": {
    "Provider": "postgresql",
    "MaxRetryCount": 3,
    "CommandTimeout": 30
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=PlotCAD;Username=plotcad;Password=plotcad_dev;"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "Frontend": {
    "AllowedOrigins": ["http://localhost:3000", "http://127.0.0.1:3000"]
  },
  "Jwt": {
    "Issuer": "https://localhost",
    "Key": "Y0uR$3cr3tK3y!123456789ABCDEF12$Up3rS3cur3K3y9876543210!QWERTY"
  },
  "InternalApi": {
    "Key": "REPLACE_WITH_SECRET_SHARED_WITH_LANDING_PAGE"
  },
  "FieldEncryption": {
    "EncryptedDataKey": "REPLACE_WITH_RSA_ENCRYPTED_AES_KEY_BASE64",
    "RsaPrivateKeyPem": ""
  }
}
